#!/usr/bin/env bash
set -euo pipefail

# Kotlin outline wrapper.
#
# Prints a compact declaration outline for Kotlin files or directories using
# ast-grep. It is intended for fast navigation before opening large renderer,
# Compose modifier, or Android UI files.
#
# Expected arguments:
#   development/kotlin-outline <file-or-directory> [more paths]
#   development/kotlin-outline <path> --include-private
#   development/kotlin-outline <path> --annotations Composable,Stable
#
# Returns:
#   0 when an outline is generated or no matching declarations are found.
#   Non-zero when ast-grep is missing, arguments are invalid, or parsing fails.
#
# Outputs:
#   Plain text grouped by file with package, declarations, visibility, annotations,
#   modifiers, syntactic supertypes, and line numbers.

usage() {
  sed -n '3,22p' "$0" | sed 's/^# \{0,1\}//'
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "$#" -eq 0 ]]; then
  usage
  exit 0
fi

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec python3 "$ROOT/development/kotlin-outline.py" "$@"
